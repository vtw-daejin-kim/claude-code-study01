{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-task-progress.sh\"",
            "timeout": 30,
            "statusMessage": "전체_TASK.md 진행 상황 업데이트 중..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-feature-tests.sh\"",
            "timeout": 330,
            "statusMessage": "변경된 기능의 테스트 실행 중..."
          }
        ]
      }
    ]
  }
}
